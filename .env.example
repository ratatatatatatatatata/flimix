# ============ FLIMIX environment variables ============
# Copy to .env.local and fill in. NEVER commit real values.

# --- Supabase (public: safe for browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server only — never expose) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Bunny Stream video CDN (server only) ---
# Library/API key are used for upload tooling; hostname+token key sign playback URLs.
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
BUNNY_TOKEN_AUTH_KEY=
# Signed playback URL lifetime in seconds
PLAYBACK_URL_TTL_SECONDS=3600

# --- QPay (server only) ---
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_WEBHOOK_SECRET=change-me-random-string

# --- SocialPay / Golomt (server only) ---
SOCIALPAY_BASE_URL=
SOCIALPAY_TERMINAL=
SOCIALPAY_KEY=

# --- Bank transfer instructions shown to users ---
BANK_TRANSFER_BANK_NAME=Хаан банк
BANK_TRANSFER_ACCOUNT=5000000000
BANK_TRANSFER_HOLDER=Флимикс ХХК

# --- Security ---
# Random 32+ char string used to hash IPs in watch_sessions
IP_HASH_SALT=change-me-to-a-long-random-string
